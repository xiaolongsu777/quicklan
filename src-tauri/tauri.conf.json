{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickLAN",
  "version": "0.1.3",
  "identifier": "com.quicklan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QuickLAN",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "QuickLAN",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["SimpChinese"],
        "installMode": "both",
        "startMenuFolder": "QuickLAN",
        "installerHooks": "windows/hooks.nsi"
      }
    }
  }
}
